<file path="frontend/src/styles/game-center.css">
/* =====================================================
    GAME CENTER PAGE (Dashboard)
    ===================================================== */

.game-center {
  max-width: 1200px;
  margin: 0 auto;
  padding: 32px;
  background: #f5f6f7;
  font-family: "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  color: #2b2f33;
}

.game-center h1 {
  font-size: 24px;
  font-weight: 600;
  margin-bottom: 24px;
}

/* =====================================================
    GAME GRID & TILES
    ===================================================== */

.game-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
  gap: 24px;
  align-items: stretch; 
}

.game-tile {
  background: #ffffff;
  border: 1px solid #dcdfe3;
  border-radius: 8px;
  padding: 24px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start; 
  height: 100%;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.game-tile:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
}

.game-tile-title {
  font-size: 18px;
  font-weight: 600;
  margin: 0 0 8px 0;
  color: #111827;
}

.game-tile-description {
  font-size: 14px;
  color: #5f6b7a;
  line-height: 1.5;
  margin: 0 0 24px 0;
  flex-grow: 1; 
}

/* Stats Section (Dashboard Tiles) */
.game-tile-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16px;
  border-top: 1px solid #f0f1f3;
  margin-top: auto;
}

.game-tile-stat {
  font-size: 13px;
  font-weight: 500;
  color: #6b7280;
}

.game-tile-stat span {
  color: #111827;
  font-weight: 600;
  margin-left: 4px;
}

/* =====================================================
    FLASHCARD BLITZ MODE SELECTOR
    ===================================================== */

.game-mode-selector {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
  margin: 24px 0;
}

.mode-card {
  background: #ffffff;
  border: 2px solid #e5e7eb;
  border-radius: 10px;
  padding: 20px;
  text-align: left; /* Aligns with instructions style */
  cursor: pointer;
  transition: all 0.2s ease;
  display: flex;
  flex-direction: column;
}

.mode-card:hover {
  border-color: #cbd5e1;
  background: #f8fafc;
}

.mode-card.active {
  border-color: #1f4fd8;
  background: #eff6ff;
  box-shadow: 0 0 0 1px #1f4fd8;
}

.mode-card strong {
  font-size: 16px;
  color: #111827;
  margin-bottom: 8px;
  display: block;
}

.mode-card p {
  font-size: 13px;
  color: #64748b;
  line-height: 1.4;
  margin: 0 0 16px 0;
  flex-grow: 1;
}

.mode-score {
  font-size: 12px;
  font-weight: 600;
  color: #6b7280;
  text-transform: uppercase;
  letter-spacing: 0.025em;
  padding-top: 12px;
  border-top: 1px solid rgba(0,0,0,0.05);
}

.mode-score span {
  color: #1f4fd8;
  margin-left: 4px;
}

/* =====================================================
    BUTTONS
    ===================================================== */

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10px 22px;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
  border: none;
  text-decoration: none;
}

.btn-primary {
  background: #1f4fd8;
  color: #ffffff !important;
}

.btn-primary:hover {
  background: #173ca6;
  box-shadow: 0 4px 12px rgba(31, 79, 216, 0.3);
}

.btn-secondary {
  background: #c62828;
  color: #ffffff !important;
}

.btn-secondary:hover {
  background: #a61c1c;
  box-shadow: 0 4px 12px rgba(198, 40, 40, 0.3);
}

/* =====================================================
    INTRO / INSTRUCTIONS CARD
    ===================================================== */

.game-intro-card {
  background: #ffffff;
  border: 1px solid #dcdfe3;
  border-radius: 12px;
  padding: 40px;
  max-width: 850px;
  margin: 40px auto;
  box-shadow: 0 10px 25px rgba(0,0,0,0.05);
}

.game-intro-card h2 {
  font-size: 24px;
  font-weight: 700;
  margin-bottom: 16px;
}

.game-intro-text {
  font-size: 15px;
  line-height: 1.6;
  color: #374151;
  margin-bottom: 20px;
}

.game-intro-list {
  margin: 0 0 32px 20px;
  padding: 0;
  color: #4b5563;
}

.game-intro-list li {
  margin-bottom: 8px;
  font-size: 14px;
}

.game-intro-actions {
  display: flex;
  gap: 16px;
  margin-top: 32px;
  border-top: 1px solid #f0f1f3;
  padding-top: 24px;
}

/* =====================================================
    RESPONSIVE
    ===================================================== */

@media (max-width: 700px) {
  .game-grid { grid-template-columns: 1fr; }
  .game-mode-selector { grid-template-columns: 1fr; }
  .game-intro-actions { flex-direction: column; }
  .game-intro-actions .btn { width: 100%; }
}

.game-category { margin-top: 48px; }
.game-category-title { 
  margin-bottom: 20px; 
  font-size: 20px;
  font-weight: 600; 
  display: flex; 
  align-items: center; 
  gap: 10px; 
}
.route-transition-overlay { position: absolute; inset: 0; background: #f5f6f7; z-index: 10; pointer-events: none; }

/* =====================================================
   GENERIC GAME TEXT HELPERS (NO INLINE STYLES)
   ===================================================== */

.game-label-spacer {
  margin-top: 14px;
}

.game-definition-text {
  font-size: 16px;
  margin-top: 6px;
}

.game-stats-line {
  display: flex;
  align-items: center;
  gap: 10px;
}

.game-stats-sep {
  color: #9ca3af;
  font-weight: 700;
}
