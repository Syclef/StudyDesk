            <strong>Hard</strong>
            <p>One mistake ends the run.</p>
          </button>
        </div>

        <div className="game-intro-actions">
          <button
            className="btn btn-primary"
            onClick={() => setStarted(true)}
          >
            Start Playing
          </button>

          <button
            className="btn btn-secondary"
            onClick={() => navigate("/games")}
          >
            Back to Game Center
          </button>
        </div>
      </div>
    </div>
  );
}
